# =============================================================================
# Lemonade Eval Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env file to version control.
# =============================================================================

# =============================================================================
# Backend Environment Variables (dashboard/backend/)
# =============================================================================

# Application Settings
# --------------------
# Application name displayed in the UI
APP_NAME="Lemonade Eval Dashboard"

# Application version
APP_VERSION="1.0.0"

# Enable debug mode for development (set to false in production)
DEBUG=true

# Enable testing mode (used for running tests)
TESTING=false

# API Settings
# ------------
# API version prefix
API_V1_PREFIX="/api/v1"

# Allowed hosts (comma-separated list, use "*" for development)
ALLOWED_HOSTS="*"

# CORS origins (comma-separated list of allowed frontend URLs)
# Default includes common development ports
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173"

# Database Configuration
# ----------------------
# PostgreSQL database connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lemonade_dashboard"

# Async database URL (for async operations)
DATABASE_ASYNC_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/lemonade_dashboard"

# For testing with SQLite (optional)
# TEST_DATABASE_URL="sqlite:///./test.db"

# Security Settings
# -----------------
# CRITICAL: Secret key for JWT token generation
#
# Generate a secure secret key using:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# SECURITY REQUIREMENTS:
# - MUST be at least 32 characters long
# - MUST be generated using a cryptographically secure random generator
# - MUST be unique for each environment (development, staging, production)
# - NEVER use default, weak, or example keys in production
# - NEVER commit .env file to version control
#
# WARNING: Using weak or default keys in production is a CRITICAL security risk!
# Compromised keys can lead to unauthorized access and token forgery.
SECRET_KEY="your-secret-key-change-in-production"

# JWT token algorithm
ALGORITHM="HS256"

# Access token expiration in minutes (default: 30 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API key prefix for identification
API_KEY_PREFIX="ledash_"

# Pagination Settings
# -------------------
# Default number of items per page
DEFAULT_PAGE_SIZE=20

# Maximum number of items per page
MAX_PAGE_SIZE=100

# WebSocket Settings
# ------------------
# WebSocket API prefix
WS_V1_PREFIX="/ws/v1"

# File Storage
# ------------
# Lemonade cache directory (optional, for importing evaluations)
# CACHE_DIR=""

# =============================================================================
# Frontend Environment Variables (dashboard/frontend/)
# =============================================================================

# API Configuration
# -----------------
# Backend API base URL
# For development with proxy, use relative path or http://localhost:8000
VITE_API_BASE_URL="http://localhost:8000"

# Application Settings
# --------------------
# Enable development mode features (optional)
VITE_DEBUG=true

# Application title (optional, overrides default)
# VITE_APP_TITLE="Lemonade Eval Dashboard"

# Feature Flags (optional)
# ------------------------
# Enable/disable specific features
# VITE_ENABLE_AUTH=true
# VITE_ENABLE_WEBSOCKET=true
# VITE_ENABLE_FILE_IMPORT=true

# =============================================================================
# Production Environment Variables
# =============================================================================
# For production deployment, ensure the following are set:
#
# Backend:
# - SECRET_KEY: Must be a secure, randomly generated 32+ character string
# - DEBUG=false
# - DATABASE_URL: Production PostgreSQL connection string
# - CORS_ORIGINS: Restrict to your production frontend domain(s)
#
# Frontend:
# - VITE_API_BASE_URL: Production API URL
# =============================================================================
